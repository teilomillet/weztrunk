#!/usr/bin/env bash

set -u

config_path=${WEZTRUNK_REPOS_PATH:-"$HOME/.config/weztrunk/repos.txt"}
runner=${WEZTRUNK_WORKTRUNK_RUNNER:-"$HOME/.local/bin/wt-code"}
reconcile_state_dir=${WEZTRUNK_RECONCILE_STATE_DIR:-"${XDG_STATE_HOME:-$HOME/.local/state}/weztrunk/reconcile"}
agent_mode=conflict
repo_arg=
base_ref=
script_path=${BASH_SOURCE[0]:-$0}
watch_interval=${WEZTRUNK_RECONCILE_WATCH_INTERVAL:-30}
watch_stable=${WEZTRUNK_RECONCILE_WATCH_STABLE:-5}
watch_once=0

usage() {
  cat >&2 <<'EOF'
Usage:
  weztrunk-reconcile status [--config PATH]
  weztrunk-reconcile current [--repo PATH] [--base REF] [--agent conflict|always|never]
  weztrunk-reconcile promote [--repo PATH] [--scratch BRANCH_OR_PATH] [--target BRANCH] [--base REF] [--check CMD] [--remove]
  weztrunk-reconcile adopt [--repo PATH] [--scratch BRANCH_OR_PATH] [--target BRANCH] [--base REF] [--check CMD] [--remove]
  weztrunk-reconcile prune [--repo PATH] [--days N] [--keep N] [--dry-run]
  weztrunk-reconcile watch [--repo PATH] [--base REF] [--interval SECONDS] [--stable SECONDS] [--agent conflict|always|never]
  weztrunk-reconcile watch-all [--config PATH] [--repo PATH] [--base REF] [--interval SECONDS] [--stable SECONDS] [--agent conflict|always|never] [--once]

Creates a scratch reconciliation worktree so current work can be rebased on top
of the latest base without rewriting the active worktree.
EOF
  exit 64
}

expand_path() {
  local raw
  raw=$1

  case "$raw" in
    '~')
      printf '%s\n' "$HOME"
      ;;
    '~/'*)
      printf '%s/%s\n' "$HOME" "${raw#\~/}"
      ;;
    '$HOME')
      printf '%s\n' "$HOME"
      ;;
    '$HOME/'*)
      printf '%s/%s\n' "$HOME" "${raw#\$HOME/}"
      ;;
    *)
      printf '%s\n' "$raw"
      ;;
  esac
}

sanitize() {
  local value
  value=$(printf '%s' "$1" | tr '/[:space:]' '--' | tr -cs '[:alnum:]._-' '-')
  value=${value#-}
  value=${value%-}
  printf '%s\n' "${value:-work}"
}

find_bin() {
  local bin_name fallback
  bin_name=$1
  shift

  if command -v "$bin_name" >/dev/null 2>&1; then
    command -v "$bin_name"
    return 0
  fi

  for fallback in "$@"; do
    if [ -n "$fallback" ] && [ -x "$fallback" ]; then
      printf '%s\n' "$fallback"
      return 0
    fi
  done

  return 1
}

git_bin=$(find_bin git /usr/bin/git) || {
  printf 'git not found. Install git or set PATH.\n' >&2
  exit 127
}

is_uint() {
  case "$1" in
    ''|*[!0-9]*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

hash_stdin() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | awk '{print $1}'
  else
    cksum | awk '{print $1 "-" $2}'
  fi
}

hash_file_path() {
  local file
  file=$1

  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | awk '{print $1}'
  else
    cksum "$file" | awk '{print $1 "-" $2}'
  fi
}

repo_root_for() {
  "$git_bin" -C "$1" rev-parse --show-toplevel 2>/dev/null
}

repo_name_for() {
  local repo common_dir
  repo=$1
  common_dir=$("$git_bin" -C "$repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1

  if [ "$(basename "$common_dir")" = ".git" ]; then
    basename "$(dirname "$common_dir")"
    return
  fi

  basename "$common_dir"
}

current_branch_for() {
  "$git_bin" -C "$1" branch --show-current 2>/dev/null || true
}

is_reconcile_branch() {
  case "$1" in
    weztrunk/reconcile/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

dirty_count_for() {
  "$git_bin" -C "$1" status --porcelain=v1 2>/dev/null |
    sed '/^?? \.codex$/d;/^?? \.codex\//d;/^?? \.weztrunk$/d;/^?? \.weztrunk\//d;/^?? \.worktrees$/d;/^?? \.worktrees\//d' |
    wc -l |
    tr -d ' '
}

dirty_fingerprint_for() {
  local repo base path file
  repo=$1
  base=$2

  {
    printf 'head\t'
    "$git_bin" -C "$repo" rev-parse HEAD 2>/dev/null || true
    printf 'base\t'
    "$git_bin" -C "$repo" rev-parse "${base}^{commit}" 2>/dev/null || printf '%s\n' "$base"
    printf 'status\n'
    "$git_bin" -C "$repo" status --porcelain=v1 2>/dev/null |
      sed '/^?? \.codex$/d;/^?? \.codex\//d;/^?? \.weztrunk$/d;/^?? \.weztrunk\//d;/^?? \.worktrees$/d;/^?? \.worktrees\//d'
    printf '\nstaged\n'
    "$git_bin" -C "$repo" diff --staged --binary
    printf '\nunstaged\n'
    "$git_bin" -C "$repo" diff --binary
    printf '\nuntracked\n'
    "$git_bin" -C "$repo" ls-files --others --exclude-standard -z |
      while IFS= read -r -d '' path; do
        case "$path" in
          .codex|.codex/*|.weztrunk|.weztrunk/*|.worktrees|.worktrees/*)
            continue
            ;;
        esac

        file=$repo/$path
        printf '%s\t' "$path"
        if [ -f "$file" ]; then
          hash_file_path "$file"
        else
          printf 'missing-or-not-file\n'
        fi
      done
  } | hash_stdin
}

fingerprint_key_for() {
  printf '%s\t%s' "$1" "$2" | hash_stdin
}

fingerprint_file_for() {
  printf '%s/fingerprints/%s\n' "$reconcile_state_dir" "$1"
}

read_synced_fingerprint() {
  local key file
  key=$1
  file=$(fingerprint_file_for "$key")
  if [ -r "$file" ]; then
    sed -n '1p' "$file"
  fi
}

write_synced_fingerprint() {
  local key fingerprint file
  key=$1
  fingerprint=$2
  file=$(fingerprint_file_for "$key")
  mkdir -p "$(dirname "$file")" || return 1
  printf '%s\n' "$fingerprint" > "$file"
}

origin_head_for() {
  local repo head
  repo=$1
  head=$("$git_bin" -C "$repo" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)

  if [ -n "$head" ]; then
    printf '%s\n' "$head"
    return
  fi

  if "$git_bin" -C "$repo" show-ref --verify --quiet refs/remotes/origin/main; then
    printf 'origin/main\n'
    return
  fi

  if "$git_bin" -C "$repo" show-ref --verify --quiet refs/remotes/origin/master; then
    printf 'origin/master\n'
    return
  fi

  printf 'HEAD\n'
}

branch_exists() {
  "$git_bin" -C "$1" show-ref --verify --quiet "refs/heads/$2"
}

branch_config_get() {
  "$git_bin" -C "$1" config --get "branch.$2.$3" 2>/dev/null || true
}

branch_config_set() {
  "$git_bin" -C "$1" config "branch.$2.$3" "$4" >/dev/null 2>&1 || true
}

branch_config_remove() {
  "$git_bin" -C "$1" config --remove-section "branch.$2" >/dev/null 2>&1 || true
}

copy_untracked_to_scratch() {
  local repo scratch path src dest
  repo=$1
  scratch=$2

  while IFS= read -r -d '' path; do
    case "$path" in
      .codex|.codex/*|.git|.git/*|.weztrunk|.weztrunk/*|.worktrees|.worktrees/*)
        continue
        ;;
    esac

    src=$repo/$path
    dest=$scratch/$path
    if [ -e "$src" ]; then
      mkdir -p "$(dirname "$dest")"
      cp -a "$src" "$dest"
    fi
  done < <("$git_bin" -C "$repo" ls-files --others --exclude-standard -z)
}

ensure_local_exclude() {
  local repo pattern exclude_path
  repo=$1
  pattern=$2

  exclude_path=$("$git_bin" -C "$repo" rev-parse --path-format=absolute --git-path info/exclude 2>/dev/null) || return 0
  mkdir -p "$(dirname "$exclude_path")" 2>/dev/null || return 0
  touch "$exclude_path" 2>/dev/null || return 0

  if ! grep -Fxq -- "$pattern" "$exclude_path"; then
    printf '%s\n' "$pattern" >> "$exclude_path"
  fi
}

apply_patch_file() {
  local scratch patch_file mode
  scratch=$1
  patch_file=$2
  mode=$3

  [ -s "$patch_file" ] || return 0

  case "$mode" in
    staged)
      "$git_bin" -C "$scratch" apply --index --whitespace=nowarn "$patch_file" ||
        "$git_bin" -C "$scratch" apply --reject --whitespace=nowarn "$patch_file"
      ;;
    unstaged)
      "$git_bin" -C "$scratch" apply --whitespace=nowarn "$patch_file" ||
        "$git_bin" -C "$scratch" apply --reject --whitespace=nowarn "$patch_file"
      ;;
  esac
}

copy_dirty_to_scratch() {
  local repo scratch patch_dir patch_failed
  repo=$1
  scratch=$2
  patch_dir=$(mktemp -d "${TMPDIR:-/tmp}/weztrunk-reconcile.XXXXXX") || return 1
  patch_failed=0

  "$git_bin" -C "$repo" diff --staged --binary > "$patch_dir/staged.patch"
  "$git_bin" -C "$repo" diff --binary > "$patch_dir/unstaged.patch"

  apply_patch_file "$scratch" "$patch_dir/staged.patch" staged || patch_failed=1
  apply_patch_file "$scratch" "$patch_dir/unstaged.patch" unstaged || patch_failed=1
  copy_untracked_to_scratch "$repo" "$scratch"

  if [ -n "$("$git_bin" -C "$scratch" status --porcelain=v1 | sed '/^?? \.codex$/d;/^?? \.codex\//d;/^?? \.weztrunk$/d;/^?? \.weztrunk\//d;/^?? \.worktrees$/d;/^?? \.worktrees\//d')" ]; then
    "$git_bin" -C "$scratch" add -A
    "$git_bin" -C "$scratch" commit -m "WIP reconcile snapshot from $(current_branch_for "$repo")" >/dev/null ||
      patch_failed=1
  fi

  rm -rf "$patch_dir"
  return "$patch_failed"
}

write_assistant_contract() {
  local scratch source source_branch scratch_branch base contract_path
  scratch=$1
  source=$2
  source_branch=$3
  scratch_branch=$4
  base=$5
  contract_path=$scratch/.weztrunk/INTENT.md

  ensure_local_exclude "$scratch" '.weztrunk/'
  mkdir -p "$(dirname "$contract_path")" || return 1
  cat > "$contract_path" <<EOF
# WezTrunk Reconcile Intent

This worktree is a WezTrunk reconcile integration candidate.

- Source worktree: ${source}
- Source branch: ${source_branch}
- Scratch branch: ${scratch_branch}
- Base: ${base}

Assistant contract:

- Keep ${base} first and put the user's work above it.
- Resolve rebase, patch, or semantic conflicts in this scratch worktree.
- Commit the resolved result on ${scratch_branch}.
- Do not edit, reset, or rewrite the source worktree.
- Do not push from this scratch worktree.
- Leave the result ready for review and fast-forward promotion.
EOF
}

launch_agent() {
  local scratch repo_name scratch_branch base reason prompt
  scratch=$1
  repo_name=$2
  scratch_branch=$3
  base=$4
  reason=$5

  prompt="Reconcile this scratch worktree.

Goal:
- Keep the user's work on top of ${base}.
- Resolve any rebase, patch, or semantic conflicts.
- Treat this worktree as the integration candidate: base first, user work above it, ready to be reviewed and promoted by fast-forward.
- Preserve the active/original worktree; only edit this scratch worktree.
- Commit the resolved result on ${scratch_branch}.
- Do not push.

Context:
- Scratch worktree: ${scratch}
- Scratch branch: ${scratch_branch}
- Reason: ${reason}

After resolving, summarize what changed and what still needs review."

  if [ ! -x "$runner" ]; then
    printf 'Codex launcher not found: %s\n' "$runner" >&2
    printf 'Open %s manually and run your agent there.\n' "$scratch" >&2
    return 127
  fi

  if [ ! -t 0 ]; then
    printf 'Reconcile worktree ready: %s\n' "$scratch"
    printf 'Launch manually:\n'
    printf '  cd %s && %s %s %s %s\n' "$scratch" "$runner" "$repo_name" "$(sanitize "$scratch_branch")" "'${prompt}'"
    return 0
  fi

  (
    cd "$scratch" || exit 1
    exec "$runner" "$repo_name" "$(sanitize "$scratch_branch")" "$prompt"
  )
}

create_reconcile_scratch() {
  local source base mode scratch_owner branch repo_name stamp safe_branch scratch_branch counter scratch_path needs_agent reason
  source=$1
  base=$2
  mode=$3
  scratch_owner=${4:-$source}
  branch=$(current_branch_for "$source")

  if [ -z "$branch" ]; then
    printf 'Current worktree is detached; cannot create reconciliation branch: %s\n' "$source" >&2
    return 64
  fi

  repo_name=$(repo_name_for "$source")
  stamp=$(date -u +%Y%m%dT%H%M%SZ)
  safe_branch=$(sanitize "$branch")
  scratch_branch=weztrunk/reconcile/${safe_branch}-${stamp}
  counter=2
  while "$git_bin" -C "$source" show-ref --verify --quiet "refs/heads/$scratch_branch"; do
    scratch_branch=weztrunk/reconcile/${safe_branch}-${stamp}-${counter}
    counter=$((counter + 1))
  done
  scratch_path=$scratch_owner/.worktrees/$(sanitize "$scratch_branch")

  ensure_local_exclude "$scratch_owner" '.worktrees/'
  if ! mkdir -p "$(dirname "$scratch_path")"; then
    printf 'Cannot create scratch worktree parent: %s\n' "$(dirname "$scratch_path")" >&2
    return 73
  fi

  if ! "$git_bin" -C "$source" branch "$scratch_branch" "$branch"; then
    printf 'Cannot create scratch branch: %s\n' "$scratch_branch" >&2
    return 1
  fi

  if ! "$git_bin" -C "$source" worktree add "$scratch_path" "$scratch_branch"; then
    "$git_bin" -C "$source" branch -D "$scratch_branch" >/dev/null 2>&1 || true
    printf 'Cannot create scratch worktree: %s\n' "$scratch_path" >&2
    return 1
  fi

  branch_config_set "$source" "$scratch_branch" weztrunk-source-branch "$branch"
  branch_config_set "$source" "$scratch_branch" weztrunk-source-worktree "$source"
  branch_config_set "$source" "$scratch_branch" weztrunk-base "$base"
  branch_config_set "$source" "$scratch_branch" weztrunk-created "$stamp"
  write_assistant_contract "$scratch_path" "$source" "$branch" "$scratch_branch" "$base" || true

  needs_agent=0
  reason=

  if [ "$(dirty_count_for "$source")" != "0" ]; then
    printf 'Copying dirty work from %s into scratch worktree...\n' "$source"
    if ! copy_dirty_to_scratch "$source" "$scratch_path"; then
      needs_agent=1
      reason='dirty work did not apply cleanly to scratch branch'
    fi
  fi

  if [ "$needs_agent" -eq 0 ]; then
    printf 'Rebasing %s onto %s in scratch worktree...\n' "$scratch_branch" "$base"
    if ! "$git_bin" -C "$scratch_path" rebase "$base"; then
      needs_agent=1
      reason='rebase conflict'
    fi
  fi

  printf 'Scratch worktree: %s\n' "$scratch_path"
  printf 'Scratch branch: %s\n' "$scratch_branch"

  if [ "$mode" = always ] || { [ "$mode" = conflict ] && [ "$needs_agent" -eq 1 ]; }; then
    launch_agent "$scratch_path" "$repo_name" "$scratch_branch" "$base" "${reason:-requested review}"
  elif [ "$needs_agent" -eq 1 ]; then
    printf 'Reconciliation needs manual work: %s.\n' "${reason:-unknown issue}"
    printf 'Open the scratch worktree and resolve it there before merging.\n'
  else
    printf 'Reconciliation completed without conflicts. Review the scratch branch before merging.\n'
  fi
}

worktree_rows_for_repo() {
  local root
  root=$1

  "$git_bin" -C "$root" worktree list --porcelain |
    awk '
      /^worktree / { path=$2 }
      /^branch / { branch=$2; sub("^refs/heads/", "", branch) }
      /^detached$/ { branch="detached" }
      /^$/ {
        if (path != "") {
          print path "\t" branch
        }
        path=""; branch="-"
      }
      END {
        if (path != "") {
          print path "\t" branch
        }
      }
    '
}

worktree_path_for_branch() {
  local root target path branch
  root=$1
  target=$2

  while IFS="$(printf '\t')" read -r path branch; do
    if [ "$branch" = "$target" ]; then
      printf '%s\n' "$path"
      return 0
    fi
  done < <(worktree_rows_for_repo "$root")

  return 1
}

scratch_timestamp_for_branch() {
  local branch rest
  branch=$1
  rest=${branch#weztrunk/reconcile/}
  printf '%s\n' "$rest" |
    sed -n 's/^.*-\([0-9]\{8\}T[0-9]\{6\}Z\)\(-[0-9][0-9]*\)\{0,1\}$/\1/p'
}

scratch_group_for_branch() {
  local root branch source rest suffix
  root=$1
  branch=$2

  source=$(branch_config_get "$root" "$branch" weztrunk-source-branch)
  if [ -n "$source" ]; then
    printf '%s\n' "$source"
    return
  fi

  rest=${branch#weztrunk/reconcile/}
  suffix=$(printf '%s\n' "$rest" |
    sed -n 's/^.*\(-[0-9]\{8\}T[0-9]\{6\}Z\(-[0-9][0-9]*\)\{0,1\}\)$/\1/p')
  if [ -n "$suffix" ]; then
    printf '%s\n' "${rest%"$suffix"}"
  else
    printf '%s\n' "$rest"
  fi
}

find_latest_scratch_for_target() {
  local root target rows path branch source safe_target stamp line
  root=$1
  target=$2
  rows=$(mktemp "${TMPDIR:-/tmp}/weztrunk-scratch.XXXXXX") || return 1
  safe_target=$(sanitize "$target")

  while IFS="$(printf '\t')" read -r path branch; do
    is_reconcile_branch "$branch" || continue
    source=$(branch_config_get "$root" "$branch" weztrunk-source-branch)
    case "$branch" in
      weztrunk/reconcile/${safe_target}-*)
        ;;
      *)
        [ "$source" = "$target" ] || continue
        ;;
    esac
    if [ -n "$source" ] && [ "$source" != "$target" ]; then
      continue
    fi
    stamp=$(scratch_timestamp_for_branch "$branch")
    printf '%s\t%s\t%s\n' "${stamp:-00000000T000000Z}" "$branch" "$path"
  done < <(worktree_rows_for_repo "$root") > "$rows"

  line=$(sort -t "$(printf '\t')" -k1,1r "$rows" | sed -n '1p')
  rm -f "$rows"
  [ -n "$line" ] || return 1
  printf '%s\n' "$line"
}

timestamp_epoch() {
  local stamp compact ymd hms formatted
  stamp=$1
  compact=${stamp%Z}
  ymd=${compact%T*}
  hms=${compact#*T}
  formatted="${ymd:0:4}-${ymd:4:2}-${ymd:6:2} ${hms:0:2}:${hms:2:2}:${hms:4:2}"

  if date -u -d "$formatted" +%s >/dev/null 2>&1; then
    date -u -d "$formatted" +%s
    return
  fi

  if date -u -j -f '%Y%m%dT%H%M%SZ' "$stamp" +%s >/dev/null 2>&1; then
    date -u -j -f '%Y%m%dT%H%M%SZ' "$stamp" +%s
    return
  fi

  printf '0\n'
}

promote_reconcile() {
  local repo_input repo root scratch_arg scratch_path scratch_branch target_branch source_branch base check_cmd remove_after
  local current line stamp target_path scratch_dirty target_dirty target_head scratch_head safety_branch counter admin_path
  scratch_arg=
  scratch_path=
  scratch_branch=
  target_branch=
  check_cmd=
  remove_after=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        shift
        [ "$#" -gt 0 ] || usage
        repo_arg=$1
        ;;
      --scratch)
        shift
        [ "$#" -gt 0 ] || usage
        scratch_arg=$1
        ;;
      --target)
        shift
        [ "$#" -gt 0 ] || usage
        target_branch=$1
        ;;
      --base)
        shift
        [ "$#" -gt 0 ] || usage
        base_ref=$1
        ;;
      --check)
        shift
        [ "$#" -gt 0 ] || usage
        check_cmd=$1
        ;;
      --remove)
        remove_after=1
        ;;
      *)
        usage
        ;;
    esac
    shift
  done

  repo_input=${repo_arg:-$PWD}
  if [ -z "${repo_arg:-}" ] && [ -n "$scratch_arg" ] && repo_root_for "$scratch_arg" >/dev/null 2>&1; then
    repo_input=$scratch_arg
  fi
  repo=$(repo_root_for "$repo_input") || {
    printf 'Not inside a git repository: %s\n' "$repo_input" >&2
    return 64
  }
  root=$repo

  "$git_bin" -C "$root" fetch --prune origin >/dev/null 2>&1 || true
  base=${base_ref:-$(origin_head_for "$root")}

  if [ -n "$scratch_arg" ]; then
    if repo_root_for "$scratch_arg" >/dev/null 2>&1; then
      scratch_path=$(repo_root_for "$scratch_arg")
      scratch_branch=$(current_branch_for "$scratch_path")
      root=$scratch_path
    else
      scratch_branch=$scratch_arg
      scratch_path=$(worktree_path_for_branch "$root" "$scratch_branch" || true)
    fi
  else
    current=$(current_branch_for "$repo")
    if is_reconcile_branch "$current"; then
      scratch_branch=$current
      scratch_path=$repo
      root=$repo
    else
      target_branch=${target_branch:-$current}
      line=$(find_latest_scratch_for_target "$root" "$target_branch" || true)
      if [ -n "$line" ]; then
        IFS="$(printf '\t')" read -r stamp scratch_branch scratch_path <<EOF
$line
EOF
      fi
    fi
  fi

  if [ -z "$scratch_branch" ] || ! is_reconcile_branch "$scratch_branch"; then
    printf 'No reconcile scratch branch selected. Use --scratch BRANCH_OR_PATH.\n' >&2
    return 64
  fi
  branch_exists "$root" "$scratch_branch" || {
    printf 'Scratch branch not found: %s\n' "$scratch_branch" >&2
    return 66
  }
  if [ -z "$scratch_path" ]; then
    scratch_path=$(worktree_path_for_branch "$root" "$scratch_branch" || true)
  fi
  if [ -z "$scratch_path" ]; then
    printf 'Scratch branch is not checked out in a worktree: %s\n' "$scratch_branch" >&2
    return 66
  fi

  source_branch=$(branch_config_get "$root" "$scratch_branch" weztrunk-source-branch)
  target_branch=${target_branch:-$source_branch}
  if [ -z "$target_branch" ]; then
    printf 'Target branch is unknown for %s. Use --target BRANCH.\n' "$scratch_branch" >&2
    return 64
  fi
  if [ "$target_branch" = "$scratch_branch" ]; then
    printf 'Target branch cannot be the scratch branch.\n' >&2
    return 64
  fi
  branch_exists "$root" "$target_branch" || {
    printf 'Target branch not found: %s\n' "$target_branch" >&2
    return 66
  }

  scratch_dirty=$(dirty_count_for "$scratch_path")
  if [ "$scratch_dirty" != "0" ]; then
    printf 'Cannot promote dirty scratch worktree (%s local change(s)): %s\n' "$scratch_dirty" "$scratch_path" >&2
    return 65
  fi
  if ! "$git_bin" -C "$root" merge-base --is-ancestor "$base" "$scratch_branch" 2>/dev/null; then
    printf 'Cannot promote: %s is not on top of %s.\n' "$scratch_branch" "$base" >&2
    return 65
  fi
  if ! "$git_bin" -C "$root" merge-base --is-ancestor "$target_branch" "$scratch_branch" 2>/dev/null; then
    printf 'Cannot promote by fast-forward: %s is not an ancestor of %s.\n' "$target_branch" "$scratch_branch" >&2
    printf 'Keep resolving in the scratch worktree or replace the branch manually after review.\n' >&2
    return 65
  fi

  if [ -n "$check_cmd" ]; then
    printf 'Running check in scratch worktree: %s\n' "$check_cmd"
    (cd "$scratch_path" && sh -c "$check_cmd") || return $?
  fi

  target_path=$(worktree_path_for_branch "$root" "$target_branch" || true)
  if [ -n "$target_path" ]; then
    target_dirty=$(dirty_count_for "$target_path")
    if [ "$target_dirty" != "0" ]; then
      printf 'Cannot promote into dirty target worktree (%s local change(s)): %s\n' "$target_dirty" "$target_path" >&2
      return 65
    fi
  fi

  stamp=$(date -u +%Y%m%dT%H%M%SZ)
  safety_branch=weztrunk/safety/$(sanitize "$target_branch")-before-promote-$stamp
  counter=2
  while branch_exists "$root" "$safety_branch"; do
    safety_branch=weztrunk/safety/$(sanitize "$target_branch")-before-promote-$stamp-$counter
    counter=$((counter + 1))
  done
  "$git_bin" -C "$root" branch "$safety_branch" "$target_branch" || return 1

  if [ -n "$target_path" ]; then
    "$git_bin" -C "$target_path" merge --ff-only "$scratch_branch" || return 1
  else
    "$git_bin" -C "$root" branch -f "$target_branch" "$scratch_branch" || return 1
  fi

  target_head=$("$git_bin" -C "$root" rev-parse "$target_branch")
  scratch_head=$("$git_bin" -C "$root" rev-parse "$scratch_branch")
  printf 'Safety branch: %s\n' "$safety_branch"
  printf 'Promoted %s to %s\n' "$target_branch" "$target_head"

  if [ "$remove_after" -eq 1 ] && [ "$target_head" = "$scratch_head" ]; then
    admin_path=${target_path:-$root}
    if [ "$admin_path" = "$scratch_path" ]; then
      printf 'Promoted, but cannot remove the current scratch worktree from inside itself. Run prune later.\n' >&2
      return 0
    fi
    "$git_bin" -C "$admin_path" worktree remove "$scratch_path" || return 1
    "$git_bin" -C "$admin_path" branch -D "$scratch_branch" >/dev/null 2>&1 || true
    branch_config_remove "$admin_path" "$scratch_branch"
    printf 'Removed scratch worktree and branch: %s\n' "$scratch_branch"
  fi
}

adopt_reconcile() {
  local repo_input repo root scratch_arg scratch_path scratch_branch target_branch source_branch base check_cmd remove_after
  local current line stamp target_path scratch_dirty target_dirty target_head scratch_head safety_branch counter admin_path
  scratch_arg=
  scratch_path=
  scratch_branch=
  target_branch=
  check_cmd=
  remove_after=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        shift
        [ "$#" -gt 0 ] || usage
        repo_arg=$1
        ;;
      --scratch)
        shift
        [ "$#" -gt 0 ] || usage
        scratch_arg=$1
        ;;
      --target)
        shift
        [ "$#" -gt 0 ] || usage
        target_branch=$1
        ;;
      --base)
        shift
        [ "$#" -gt 0 ] || usage
        base_ref=$1
        ;;
      --check)
        shift
        [ "$#" -gt 0 ] || usage
        check_cmd=$1
        ;;
      --remove)
        remove_after=1
        ;;
      *)
        usage
        ;;
    esac
    shift
  done

  repo_input=${repo_arg:-$PWD}
  if [ -z "${repo_arg:-}" ] && [ -n "$scratch_arg" ] && repo_root_for "$scratch_arg" >/dev/null 2>&1; then
    repo_input=$scratch_arg
  fi
  repo=$(repo_root_for "$repo_input") || {
    printf 'Not inside a git repository: %s\n' "$repo_input" >&2
    return 64
  }
  root=$repo

  "$git_bin" -C "$root" fetch --prune origin >/dev/null 2>&1 || true
  base=${base_ref:-$(origin_head_for "$root")}

  if [ -n "$scratch_arg" ]; then
    if repo_root_for "$scratch_arg" >/dev/null 2>&1; then
      scratch_path=$(repo_root_for "$scratch_arg")
      scratch_branch=$(current_branch_for "$scratch_path")
      root=$scratch_path
    else
      scratch_branch=$scratch_arg
      scratch_path=$(worktree_path_for_branch "$root" "$scratch_branch" || true)
    fi
  else
    current=$(current_branch_for "$repo")
    if is_reconcile_branch "$current"; then
      scratch_branch=$current
      scratch_path=$repo
      root=$repo
    else
      target_branch=${target_branch:-$current}
      line=$(find_latest_scratch_for_target "$root" "$target_branch" || true)
      if [ -n "$line" ]; then
        IFS="$(printf '\t')" read -r stamp scratch_branch scratch_path <<EOF
$line
EOF
      fi
    fi
  fi

  if [ -z "$scratch_branch" ] || ! is_reconcile_branch "$scratch_branch"; then
    printf 'No reconcile scratch branch selected. Use --scratch BRANCH_OR_PATH.\n' >&2
    return 64
  fi
  branch_exists "$root" "$scratch_branch" || {
    printf 'Scratch branch not found: %s\n' "$scratch_branch" >&2
    return 66
  }
  if [ -z "$scratch_path" ]; then
    scratch_path=$(worktree_path_for_branch "$root" "$scratch_branch" || true)
  fi
  if [ -z "$scratch_path" ]; then
    printf 'Scratch branch is not checked out in a worktree: %s\n' "$scratch_branch" >&2
    return 66
  fi

  source_branch=$(branch_config_get "$root" "$scratch_branch" weztrunk-source-branch)
  target_branch=${target_branch:-$source_branch}
  if [ -z "$target_branch" ]; then
    printf 'Target branch is unknown for %s. Use --target BRANCH.\n' "$scratch_branch" >&2
    return 64
  fi
  if [ "$target_branch" = "$scratch_branch" ]; then
    printf 'Target branch cannot be the scratch branch.\n' >&2
    return 64
  fi
  branch_exists "$root" "$target_branch" || {
    printf 'Target branch not found: %s\n' "$target_branch" >&2
    return 66
  }

  scratch_dirty=$(dirty_count_for "$scratch_path")
  if [ "$scratch_dirty" != "0" ]; then
    printf 'Cannot adopt dirty scratch worktree (%s local change(s)): %s\n' "$scratch_dirty" "$scratch_path" >&2
    return 65
  fi
  if ! "$git_bin" -C "$root" merge-base --is-ancestor "$base" "$scratch_branch" 2>/dev/null; then
    printf 'Cannot adopt: %s is not on top of %s.\n' "$scratch_branch" "$base" >&2
    return 65
  fi

  if [ -n "$check_cmd" ]; then
    printf 'Running check in scratch worktree: %s\n' "$check_cmd"
    (cd "$scratch_path" && sh -c "$check_cmd") || return $?
  fi

  target_path=$(worktree_path_for_branch "$root" "$target_branch" || true)
  if [ -n "$target_path" ]; then
    target_dirty=$(dirty_count_for "$target_path")
    if [ "$target_dirty" != "0" ]; then
      printf 'Cannot adopt into dirty target worktree (%s local change(s)): %s\n' "$target_dirty" "$target_path" >&2
      return 65
    fi
  fi

  stamp=$(date -u +%Y%m%dT%H%M%SZ)
  safety_branch=weztrunk/safety/$(sanitize "$target_branch")-before-adopt-$stamp
  counter=2
  while branch_exists "$root" "$safety_branch"; do
    safety_branch=weztrunk/safety/$(sanitize "$target_branch")-before-adopt-$stamp-$counter
    counter=$((counter + 1))
  done
  "$git_bin" -C "$root" branch "$safety_branch" "$target_branch" || return 1

  if [ -n "$target_path" ]; then
    "$git_bin" -C "$target_path" reset --hard "$scratch_branch" || return 1
  else
    "$git_bin" -C "$root" branch -f "$target_branch" "$scratch_branch" || return 1
  fi

  target_head=$("$git_bin" -C "$root" rev-parse "$target_branch")
  scratch_head=$("$git_bin" -C "$root" rev-parse "$scratch_branch")
  printf 'Safety branch: %s\n' "$safety_branch"
  printf 'Adopted %s to %s\n' "$target_branch" "$target_head"

  if [ "$remove_after" -eq 1 ] && [ "$target_head" = "$scratch_head" ]; then
    admin_path=${target_path:-$root}
    if [ "$admin_path" = "$scratch_path" ]; then
      printf 'Adopted, but cannot remove the current scratch worktree from inside itself. Run prune later.\n' >&2
      return 0
    fi
    "$git_bin" -C "$admin_path" worktree remove "$scratch_path" || return 1
    "$git_bin" -C "$admin_path" branch -D "$scratch_branch" >/dev/null 2>&1 || true
    branch_config_remove "$admin_path" "$scratch_branch"
    printf 'Removed scratch worktree and branch: %s\n' "$scratch_branch"
  fi
}

prune_reconcile() {
  local repo_input repo root days keep dry_run rows candidates now path branch group stamp epoch age dirty line
  days=7
  keep=2
  dry_run=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        shift
        [ "$#" -gt 0 ] || usage
        repo_arg=$1
        ;;
      --days)
        shift
        [ "$#" -gt 0 ] || usage
        days=$1
        ;;
      --keep)
        shift
        [ "$#" -gt 0 ] || usage
        keep=$1
        ;;
      --dry-run)
        dry_run=1
        ;;
      *)
        usage
        ;;
    esac
    shift
  done

  repo_input=${repo_arg:-$PWD}
  repo=$(repo_root_for "$repo_input") || {
    printf 'Not inside a git repository: %s\n' "$repo_input" >&2
    return 64
  }
  root=$repo

  is_uint "$days" || usage
  is_uint "$keep" || usage

  rows=$(mktemp "${TMPDIR:-/tmp}/weztrunk-prune.XXXXXX") || return 1
  candidates=$(mktemp "${TMPDIR:-/tmp}/weztrunk-prune-candidates.XXXXXX") || {
    rm -f "$rows"
    return 1
  }
  now=$(date +%s)

  while IFS="$(printf '\t')" read -r path branch; do
    is_reconcile_branch "$branch" || continue
    stamp=$(scratch_timestamp_for_branch "$branch")
    [ -n "$stamp" ] || continue
    group=$(scratch_group_for_branch "$root" "$branch")
    printf '%s\t%s\t%s\t%s\n' "$group" "$stamp" "$path" "$branch"
  done < <(worktree_rows_for_repo "$root") > "$rows"

  sort -t "$(printf '\t')" -k1,1 -k2,2r "$rows" |
    awk -v keep="$keep" 'BEGIN { FS=OFS="\t" } { seen[$1]++; if (seen[$1] > keep) print }' > "$candidates"

  while IFS="$(printf '\t')" read -r group stamp path branch; do
    [ -n "$branch" ] || continue
    epoch=$(timestamp_epoch "$stamp")
    if [ "$epoch" -gt 0 ]; then
      age=$(((now - epoch) / 86400))
      [ "$age" -ge "$days" ] || continue
    else
      age=unknown
    fi

    dirty=$(dirty_count_for "$path")
    if [ "$dirty" != "0" ]; then
      printf 'skip dirty scratch (%s local change(s)): %s %s\n' "$dirty" "$branch" "$path"
      continue
    fi

    if [ "$dry_run" -eq 1 ]; then
      printf 'would remove %s age_days=%s path=%s\n' "$branch" "$age" "$path"
    else
      "$git_bin" -C "$root" worktree remove "$path" || continue
      "$git_bin" -C "$root" branch -D "$branch" >/dev/null 2>&1 || true
      branch_config_remove "$root" "$branch"
      printf 'removed %s age_days=%s path=%s\n' "$branch" "$age" "$path"
    fi
  done < "$candidates"

  rm -f "$rows" "$candidates"
}

status_one_repo() {
  local repo root repo_name base path branch dirty base_state
  repo=$1

  if ! root=$(repo_root_for "$repo"); then
    printf '%-18s %-18s %-8s %-12s %s\n' "$(basename "$repo")" '-' '-' 'missing' "$repo"
    return
  fi

  repo_name=$(repo_name_for "$root")
  "$git_bin" -C "$root" fetch --prune origin >/dev/null 2>&1 || true
  base=$(origin_head_for "$root")

  worktree_rows_for_repo "$root" |
    while IFS="$(printf '\t')" read -r path branch; do
      dirty=$(dirty_count_for "$path")
      if [ "$branch" != "detached" ] && "$git_bin" -C "$path" merge-base --is-ancestor "$base" HEAD 2>/dev/null; then
        base_state=on-top
      else
        base_state=needs-base
      fi
      printf '%-18s %-18s %-8s %-12s %s\n' "$repo_name" "$branch" "$dirty" "$base_state" "$path"
    done
}

process_repos() {
  local handler line repo
  handler=$1

  if [ ! -f "$config_path" ]; then
    printf 'WezTrunk repos config not found: %s\n' "$config_path" >&2
    return 66
  fi

  while IFS= read -r line || [ -n "$line" ]; do
    line=$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$line" in
      ''|'#'*)
        continue
        ;;
    esac

    repo=$(expand_path "$line")
    "$handler" "$repo"
  done < "$config_path"
}

parse_agent_mode() {
  agent_mode=$1
  case "$agent_mode" in
    conflict|always|never)
      ;;
    *)
      usage
      ;;
  esac
}

sync_worktree_once() {
  local owner_root path branch base dirty current_head base_head
  owner_root=$1
  path=$2
  branch=$3
  base=$4
  dirty=$(dirty_count_for "$path")

  if [ "$branch" = "detached" ]; then
    printf 'skip %s: detached HEAD\n' "$path"
    return 0
  fi

  if is_reconcile_branch "$branch"; then
    printf 'skip %s: reconcile scratch branch\n' "$path"
    return 0
  fi

  if [ "$dirty" = "0" ]; then
    if "$git_bin" -C "$path" merge-base --is-ancestor HEAD "$base" 2>/dev/null; then
      current_head=$("$git_bin" -C "$path" rev-parse HEAD)
      base_head=$("$git_bin" -C "$path" rev-parse "$base")
      if [ "$current_head" = "$base_head" ]; then
        printf 'ok %s: already at %s\n' "$path" "$base"
      elif "$git_bin" -C "$path" merge --ff-only "$base"; then
        printf 'ok %s: fast-forwarded %s to %s\n' "$path" "$branch" "$base"
      else
        printf 'skip %s: fast-forward failed, creating scratch reconcile worktree\n' "$path"
        create_reconcile_scratch "$path" "$base" "$agent_mode" "$owner_root"
      fi
      return 0
    fi

    if "$git_bin" -C "$path" merge-base --is-ancestor "$base" HEAD 2>/dev/null; then
      printf 'ok %s: %s already contains %s\n' "$path" "$branch" "$base"
      return 0
    fi
  fi

  if [ "$dirty" = "0" ]; then
    printf 'scratch %s: clean but not fast-forwardable to %s\n' "$path" "$base"
  else
    printf 'scratch %s: %s local change(s)\n' "$path" "$dirty"
  fi
  create_reconcile_scratch "$path" "$base" "$agent_mode" "$owner_root"
}

sync_all_repo_once() {
  local repo root base rows path branch key before after previous
  repo=$1

  if ! root=$(repo_root_for "$repo"); then
    printf 'skip %s: not a git checkout\n' "$repo"
    return 0
  fi

  if ! "$git_bin" -C "$root" fetch --prune origin; then
    printf 'skip %s: fetch from origin failed\n' "$root"
    return 0
  fi

  base=${base_ref:-$(origin_head_for "$root")}
  printf 'repo %s: base %s\n' "$(repo_name_for "$root")" "$base"

  rows=$(mktemp "${TMPDIR:-/tmp}/weztrunk-worktrees.XXXXXX") || return 1
  worktree_rows_for_repo "$root" > "$rows"
  while IFS="$(printf '\t')" read -r path branch; do
    [ -n "$path" ] || continue
    if [ "$branch" != "detached" ] && ! is_reconcile_branch "$branch"; then
      key=$(fingerprint_key_for "$root" "$path")
      before=$(dirty_fingerprint_for "$path" "$base")
      previous=$(read_synced_fingerprint "$key")
      if [ "$before" = "$previous" ]; then
        printf 'ok %s: reconcile snapshot unchanged\n' "$path"
        continue
      fi
      if sync_worktree_once "$root" "$path" "$branch" "$base"; then
        after=$(dirty_fingerprint_for "$path" "$base")
        write_synced_fingerprint "$key" "$after" || return 1
      fi
    else
      sync_worktree_once "$root" "$path" "$branch" "$base"
    fi
  done < "$rows"
  rm -f "$rows"
}

sync_all_once() {
  if [ -n "$repo_arg" ]; then
    sync_all_repo_once "$repo_arg"
  else
    process_repos sync_all_repo_once
  fi
}

watch_all_tick_repo() {
  local repo root base rows path branch key fingerprint now after
  repo=$1

  if ! root=$(repo_root_for "$repo"); then
    printf 'skip %s: not a git checkout\n' "$repo"
    return 0
  fi

  "$git_bin" -C "$root" fetch --prune origin >/dev/null 2>&1 || {
    printf 'skip %s: fetch from origin failed\n' "$root"
    return 0
  }

  base=${base_ref:-$(origin_head_for "$root")}
  rows=$(mktemp "${TMPDIR:-/tmp}/weztrunk-worktrees.XXXXXX") || return 1
  worktree_rows_for_repo "$root" > "$rows"
  while IFS="$(printf '\t')" read -r path branch; do
    [ -n "$path" ] || continue
    [ "$branch" != "detached" ] || continue
    is_reconcile_branch "$branch" && continue

    key=$(printf '%s\t%s' "$root" "$path" | hash_stdin)
    fingerprint=$(dirty_fingerprint_for "$path" "$base")
    now=$(date +%s)

    if [ "${watch_completed[$key]:-}" = "$fingerprint" ]; then
      watch_pending[$key]=
      watch_pending_since[$key]=0
    elif [ "${watch_pending[$key]:-}" != "$fingerprint" ]; then
      watch_pending[$key]=$fingerprint
      watch_pending_since[$key]=$now
      printf '%s %s change detected; waiting for stability...\n' "$(date '+%H:%M:%S')" "$path"
    elif [ $((now - ${watch_pending_since[$key]:-0})) -ge "$watch_stable" ]; then
      printf '%s syncing %s onto %s...\n' "$(date '+%H:%M:%S')" "$path" "$base"
      if sync_worktree_once "$root" "$path" "$branch" "$base"; then
        after=$(dirty_fingerprint_for "$path" "$base")
        if [ "$after" = "$fingerprint" ]; then
          watch_completed[$key]=$fingerprint
          watch_pending[$key]=
          watch_pending_since[$key]=0
          printf '%s %s sync snapshot is current.\n' "$(date '+%H:%M:%S')" "$path"
        else
          watch_pending[$key]=$after
          watch_pending_since[$key]=$(date +%s)
          printf '%s %s changed during sync; waiting for newest files...\n' "$(date '+%H:%M:%S')" "$path"
        fi
      else
        watch_pending_since[$key]=$now
        printf '%s %s sync failed; will retry after stability.\n' "$(date '+%H:%M:%S')" "$path"
      fi
    fi
  done < "$rows"
  rm -f "$rows"
}

watch_all_tick() {
  if [ -n "$repo_arg" ]; then
    watch_all_tick_repo "$repo_arg"
  else
    process_repos watch_all_tick_repo
  fi
}

cmd=${1:-status}
shift 2>/dev/null || true

case "$cmd" in
  status)
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --config)
          shift
          [ "$#" -gt 0 ] || usage
          config_path=$1
          ;;
        *)
          usage
          ;;
      esac
      shift
    done

    printf '%-18s %-18s %-8s %-12s %s\n' repo branch dirty base path
    printf '%-18s %-18s %-8s %-12s %s\n' ---- ------ ----- ---- ----
    process_repos status_one_repo
    ;;
  current|start)
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --repo)
          shift
          [ "$#" -gt 0 ] || usage
          repo_arg=$1
          ;;
        --base)
          shift
          [ "$#" -gt 0 ] || usage
          base_ref=$1
          ;;
        --agent)
          shift
          [ "$#" -gt 0 ] || usage
          parse_agent_mode "$1"
          ;;
        *)
          usage
          ;;
      esac
      shift
    done

    repo_input=${repo_arg:-$PWD}
    repo=$(repo_root_for "$repo_input") || {
      printf 'Not inside a git repository: %s\n' "$repo_input" >&2
      exit 64
    }
    branch=$(current_branch_for "$repo")
    if [ -z "$branch" ]; then
      printf 'Current worktree is detached; cannot create reconciliation branch.\n' >&2
      exit 64
    fi

    "$git_bin" -C "$repo" fetch --prune origin
    base=${base_ref:-$(origin_head_for "$repo")}
    create_reconcile_scratch "$repo" "$base" "$agent_mode" "$repo"
    ;;
  promote)
    promote_reconcile "$@"
    ;;
  adopt)
    adopt_reconcile "$@"
    ;;
  prune)
    prune_reconcile "$@"
    ;;
  watch|manager)
    agent_mode=never
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --repo)
          shift
          [ "$#" -gt 0 ] || usage
          repo_arg=$1
          ;;
        --base)
          shift
          [ "$#" -gt 0 ] || usage
          base_ref=$1
          ;;
        --interval)
          shift
          [ "$#" -gt 0 ] || usage
          watch_interval=$1
          ;;
        --stable)
          shift
          [ "$#" -gt 0 ] || usage
          watch_stable=$1
          ;;
        --agent)
          shift
          [ "$#" -gt 0 ] || usage
          parse_agent_mode "$1"
          ;;
        *)
          usage
          ;;
      esac
      shift
    done

    is_uint "$watch_interval" || usage
    is_uint "$watch_stable" || usage
    if [ "$watch_interval" -lt 1 ]; then
      printf 'Watch interval must be at least 1 second.\n' >&2
      exit 64
    fi

    repo_input=${repo_arg:-$PWD}
    repo=$(repo_root_for "$repo_input") || {
      printf 'Not inside a git repository: %s\n' "$repo_input" >&2
      exit 64
    }
    branch=$(current_branch_for "$repo")
    if [ -z "$branch" ]; then
      printf 'Current worktree is detached; cannot watch reconciliation.\n' >&2
      exit 64
    fi

    printf 'Watching %s for reconcile snapshots.\n' "$repo"
    printf 'interval=%ss stable=%ss agent=%s\n' "$watch_interval" "$watch_stable" "$agent_mode"

    last_completed=
    pending=
    pending_since=0

    while :; do
      "$git_bin" -C "$repo" fetch --prune origin >/dev/null 2>&1 || true
      base=${base_ref:-$(origin_head_for "$repo")}
      fingerprint=$(dirty_fingerprint_for "$repo" "$base")
      now=$(date +%s)

      if [ "$fingerprint" = "$last_completed" ]; then
        pending=
        pending_since=0
      elif [ "$fingerprint" != "$pending" ]; then
        pending=$fingerprint
        pending_since=$now
        printf '%s change detected; waiting for a stable checkout...\n' "$(date '+%H:%M:%S')"
      elif [ $((now - pending_since)) -ge "$watch_stable" ]; then
        printf '%s reconciling current checkout onto %s...\n' "$(date '+%H:%M:%S')" "$base"
        if "$script_path" current --repo "$repo" --base "$base" --agent "$agent_mode"; then
          after=$(dirty_fingerprint_for "$repo" "$base")
          if [ "$after" = "$fingerprint" ]; then
            last_completed=$fingerprint
            pending=
            pending_since=0
            printf '%s reconcile snapshot is current.\n' "$(date '+%H:%M:%S')"
          else
            pending=$after
            pending_since=$(date +%s)
            printf '%s checkout changed during reconcile; waiting for the newest files...\n' "$(date '+%H:%M:%S')"
          fi
        else
          pending_since=$now
          printf '%s reconcile failed; will retry after the checkout is stable.\n' "$(date '+%H:%M:%S')"
        fi
      fi

      sleep "$watch_interval"
    done
    ;;
  watch-all|manager-all)
    agent_mode=never
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --config)
          shift
          [ "$#" -gt 0 ] || usage
          config_path=$1
          ;;
        --repo)
          shift
          [ "$#" -gt 0 ] || usage
          repo_arg=$1
          ;;
        --base)
          shift
          [ "$#" -gt 0 ] || usage
          base_ref=$1
          ;;
        --interval)
          shift
          [ "$#" -gt 0 ] || usage
          watch_interval=$1
          ;;
        --stable)
          shift
          [ "$#" -gt 0 ] || usage
          watch_stable=$1
          ;;
        --agent)
          shift
          [ "$#" -gt 0 ] || usage
          parse_agent_mode "$1"
          ;;
        --once)
          watch_once=1
          ;;
        *)
          usage
          ;;
      esac
      shift
    done

    is_uint "$watch_interval" || usage
    is_uint "$watch_stable" || usage
    if [ "$watch_interval" -lt 1 ]; then
      printf 'Watch interval must be at least 1 second.\n' >&2
      exit 64
    fi

    if [ "$watch_once" -eq 1 ]; then
      sync_all_once
      exit $?
    fi

    declare -A watch_completed
    declare -A watch_pending
    declare -A watch_pending_since

    printf 'Watching all worktrees for reconcile snapshots.\n'
    printf 'interval=%ss stable=%ss agent=%s\n' "$watch_interval" "$watch_stable" "$agent_mode"

    while :; do
      watch_all_tick
      sleep "$watch_interval"
    done
    ;;
  *)
    usage
    ;;
esac
