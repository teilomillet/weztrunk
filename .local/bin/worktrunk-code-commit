#!/bin/sh

set -eu

tmp=$(mktemp)
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT HUP INT TERM

if [ -n "${WWC_AGENT_BIN:-}" ]; then
  agent_bin=$WWC_AGENT_BIN
elif command -v codex >/dev/null 2>&1; then
  agent_bin=$(command -v codex)
elif [ -x /opt/homebrew/bin/codex ]; then
  agent_bin=/opt/homebrew/bin/codex
else
  printf 'No agent CLI found. Set WWC_AGENT_BIN or install codex.\n' >&2
  exit 127
fi

"$agent_bin" exec \
  --skip-git-repo-check \
  -c model_reasoning_effort='low' \
  -c system_prompt='' \
  --sandbox read-only \
  --output-last-message "$tmp" \
  - >/dev/null 2>&1

cat "$tmp"
