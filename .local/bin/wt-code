#!/bin/sh

set -eu

if [ "$#" -lt 2 ]; then
  printf 'Usage: %s <repo> <branch> [agent args...]\n' "$0" >&2
  exit 64
fi

dispatcher=${WEZTRUNK_AGENT_DISPATCHER:-"$HOME/.local/bin/weztrunk-agent"}

if [ ! -x "$dispatcher" ]; then
  printf 'WezTrunk agent dispatcher not found: %s\n' "$dispatcher" >&2
  exit 127
fi

repo=$1
branch=$2
shift 2

socket=$("$dispatcher" socket-path "$repo" "$branch")
socket_dir=$(dirname "$socket")
mkdir -p "$socket_dir"

find_bin() {
  bin_name=$1
  shift

  if command -v "$bin_name" >/dev/null 2>&1; then
    command -v "$bin_name"
    return 0
  fi

  for fallback in "$@"; do
    if [ -n "$fallback" ] && [ -x "$fallback" ]; then
      printf '%s\n' "$fallback"
      return 0
    fi
  done

  return 1
}

dtach_bin=$(find_bin dtach /home/linuxbrew/.linuxbrew/bin/dtach /opt/homebrew/bin/dtach) || {
  printf 'dtach not found. Install it and ensure it is on PATH.\n' >&2
  exit 127
}

sleep_guard=${WEZTRUNK_SLEEP_GUARD:-auto}

case "$sleep_guard" in
  auto|'')
    if caffeinate_bin=$(find_bin caffeinate /usr/bin/caffeinate); then
      exec "$dtach_bin" -A "$socket" -z -r winch "$caffeinate_bin" -s "$dispatcher" launch "$@"
    fi

    if inhibit_bin=$(find_bin systemd-inhibit ''); then
      exec "$dtach_bin" -A "$socket" -z -r winch \
        "$inhibit_bin" \
        --what=sleep \
        --mode=block \
        --why=WezTrunk-agent-session \
        "$dispatcher" launch "$@"
    fi

    exec "$dtach_bin" -A "$socket" -z -r winch "$dispatcher" launch "$@"
    ;;
  none)
    exec "$dtach_bin" -A "$socket" -z -r winch "$dispatcher" launch "$@"
    ;;
  caffeinate)
    caffeinate_bin=$(find_bin caffeinate /usr/bin/caffeinate) || {
      printf 'WEZTRUNK_SLEEP_GUARD=caffeinate was requested, but caffeinate was not found.\n' >&2
      exit 127
    }
    exec "$dtach_bin" -A "$socket" -z -r winch "$caffeinate_bin" -s "$dispatcher" launch "$@"
    ;;
  systemd-inhibit)
    inhibit_bin=$(find_bin systemd-inhibit '') || {
      printf 'WEZTRUNK_SLEEP_GUARD=systemd-inhibit was requested, but systemd-inhibit was not found.\n' >&2
      exit 127
    }
    exec "$dtach_bin" -A "$socket" -z -r winch \
      "$inhibit_bin" \
      --what=sleep \
      --mode=block \
      --why=WezTrunk-agent-session \
      "$dispatcher" launch "$@"
    ;;
  *)
    printf 'Unknown WEZTRUNK_SLEEP_GUARD value: %s\n' "$sleep_guard" >&2
    printf 'Supported values: auto, none, caffeinate, systemd-inhibit\n' >&2
    exit 64
    ;;
esac
