#!/bin/sh

set -eu

manual_path=${WEZTRUNK_MANUAL_PATH:-"$HOME/.config/weztrunk/MANUAL.md"}

if [ ! -r "$manual_path" ]; then
  printf 'WezTrunk manual not found: %s\n' "$manual_path" >&2
  exit 127
fi

normalize_topic() {
  printf '%s' "$*" | tr '[:upper:]' '[:lower:]' | tr -s '[:space:]' ' ' | sed 's/^ //; s/ $//'
}

topic_heading() {
  case "$(normalize_topic "$*")" in
    daily|overview)
      printf 'daily use\n'
      ;;
    shell|alias|aliases)
      printf 'shell\n'
      ;;
    wezterm|keys|keybindings|shortcuts)
      printf 'wezterm\n'
      ;;
    remove|close|delete|cleanup)
      printf 'remove or close a worktree\n'
      ;;
    merge)
      printf 'merge a worktree\n'
      ;;
    switch|create|branch|worktree)
      printf 'switch or create worktrees\n'
      ;;
    session|sessions|socket|dtach|resume)
      printf 'sessions\n'
      ;;
    profile|profiles|provider|providers|model|config)
      printf 'profiles\n'
      ;;
    install|setup|sync|propagate|propagation|update)
      printf 'propagating changes\n'
      ;;
    *)
      printf '\n'
      ;;
  esac
}

show_with_pager() {
  if [ -t 1 ] && command -v glow >/dev/null 2>&1; then
    exec glow -p "$manual_path"
  fi

  if [ -t 1 ] && command -v bat >/dev/null 2>&1; then
    exec bat --paging=always --language=markdown "$manual_path"
  fi

  if [ -t 1 ] && command -v less >/dev/null 2>&1; then
    exec sh -c 'cat "$1" | ${PAGER:-less -R}' sh "$manual_path"
  fi

  exec cat "$manual_path"
}

page_stdin() {
  if [ -t 1 ] && command -v bat >/dev/null 2>&1; then
    bat --paging=always --language=markdown -
    return
  fi

  if [ -t 1 ] && command -v less >/dev/null 2>&1; then
    sh -c '${PAGER:-less -R}'
    return
  fi

  cat
}

extract_section() {
  heading=$1

  awk -v target="$heading" '
    function heading_level(line,   count) {
      count = 0
      while (substr(line, count + 1, 1) == "#") {
        count++
      }
      return count
    }

    /^#+ / {
      current_level = heading_level($0)
      current_heading = substr($0, current_level + 2)

      if (found && current_level <= target_level) {
        exit
      }

      if (tolower(current_heading) == target) {
        found = 1
        target_level = current_level
        print
        next
      }
    }

    found {
      print
    }
  ' "$manual_path"
}

show_topics() {
  cat <<'EOF'
daily      overview and day-to-day commands
shell      shell aliases and helpers
wezterm    keybindings and command palette
remove     close or delete a worktree
merge      merge a worktree back
switch     switch or create worktrees
session    detached agent sessions and cleanup
profiles   provider/profile config and examples
install    propagation, install, and sync
EOF
}

search_manual() {
  query=$1

  if [ -z "$query" ]; then
    show_with_pager
  fi

  heading=$(topic_heading "$query")
  if [ -n "$heading" ]; then
    section=$(extract_section "$heading")
    if [ -n "$section" ]; then
      printf '%s\n' "$section" | page_stdin
      exit 0
    fi
  fi

  if [ -t 1 ] && command -v less >/dev/null 2>&1; then
    exec sh -c 'rg --color=always -n -i -C 2 -- "$1" "$2" | ${PAGER:-less -R}' sh "$query" "$manual_path"
  fi

  exec rg --color=never -n -i -C 2 -- "$query" "$manual_path"
}

case "${1:-}" in
  --path)
    printf '%s\n' "$manual_path"
    ;;
  --raw)
    cat "$manual_path"
    ;;
  --topics)
    show_topics
    ;;
  --search)
    shift
    search_manual "${*:-}"
    ;;
  "")
    show_with_pager
    ;;
  *)
    search_manual "$*"
    ;;
esac
