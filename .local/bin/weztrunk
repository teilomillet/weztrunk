#!/bin/sh

set -eu

manual_runner=${WEZTRUNK_MANUAL_RUNNER:-"$HOME/.local/bin/weztrunk-manual"}
switch_runner=${WEZTRUNK_SWITCH_RUNNER:-"$HOME/.local/bin/weztrunk-switch"}
agent_runner=${WEZTRUNK_AGENT_RUNNER:-"$HOME/.local/bin/weztrunk-agent"}
config_runner=${WEZTRUNK_CONFIG_RUNNER:-"$HOME/.local/bin/weztrunk-config"}
repos_runner=${WEZTRUNK_REPOS_RUNNER:-"$HOME/.local/bin/weztrunk-repos"}
backup_runner=${WEZTRUNK_BACKUP_RUNNER:-"$HOME/.local/bin/weztrunk-backup"}
doctor_runner=${WEZTRUNK_DOCTOR_RUNNER:-"$HOME/.local/bin/weztrunk-doctor"}
reconcile_runner=${WEZTRUNK_RECONCILE_RUNNER:-"$HOME/.local/bin/weztrunk-reconcile"}

usage() {
  printf 'Usage: %s <man|profile|repos|backup|reconcile|doctor|switch|agent> [args...]\n' "$0" >&2
  exit 64
}

profile_usage() {
  printf 'Usage: %s profile [current|list [provider]|path|args <launch|commit> [provider] [profile]]\n' "$0" >&2
  exit 64
}

cmd=${1:-}
[ -n "$cmd" ] || usage
shift

case "$cmd" in
  man|manual|help)
    exec "$manual_runner" "$@"
    ;;
  profile)
    subcmd=${1:-current}
    case "$subcmd" in
      ''|current|show)
        exec "$config_runner" current
        ;;
      list|ls)
        shift
        exec "$config_runner" profiles "$@"
        ;;
      path)
        exec "$config_runner" path
        ;;
      args)
        shift
        exec "$config_runner" args "$@"
        ;;
      *)
        profile_usage
        ;;
    esac
    ;;
  repos)
    exec "$repos_runner" "$@"
    ;;
  backup|backups)
    exec "$backup_runner" "$@"
    ;;
  reconcile|resolve|sync)
    exec "$reconcile_runner" "$@"
    ;;
  doctor)
    exec "$doctor_runner" "$@"
    ;;
  switch)
    exec "$switch_runner" "$@"
    ;;
  agent)
    exec "$agent_runner" "$@"
    ;;
  *)
    usage
    ;;
esac
